SECRET_KEY={{ vault_recipes_secret_key }}
TZ=Europe/Berlin
ALLOWED_HOSTS={{ service_name }}.{{ public_domain }}

# db
DB_ENGINE=django.db.backends.postgresql
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=recipes
POSTGRES_PASSWORD={{ vault_postgres_password }}
POSTGRES_DB=recipes

# auth
ALLAUTH_TRUSTED_PROXY_COUNT=1
SOCIAL_PROVIDERS="allauth.socialaccount.providers.openid_connect"
SOCIALACCOUNT_PROVIDERS='{ "openid_connect": { "SERVERS": [ { "id": "authelia", "name": "Authelia", "server_url": "https://auth.{{ public_domain }}/.well-known/openid-configuration", "token_auth_method": "client_secret_basic", "APP": { "client_id": "tyEFQG6meV5B.D491unnc_lYGZny5DusRm0UgkpuC", "secret": "{{ vault_authelia_identity_providers_oidc_clients_recipes_client_secret }}" } } ] } }'
SOCIAL_DEFAULT_ACCESS=1
SOCIAL_DEFAULT_GROUP=user
HIDE_LOGIN_FORM=1
SOCIALACCOUNT_LOGIN_ON_GET=1
